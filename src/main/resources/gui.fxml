<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="820.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/11.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summersec.attack.UI.MainController">
    <top>
        <VBox spacing="6.0">
            <children>
                <MenuBar>
                    <menus>
                        <Menu mnemonicParsing="false" text="设置">
                            <items>
                                <MenuItem fx:id="proxySetupBtn" mnemonicParsing="false" text="代理" />
                            </items>
                        </Menu>
                    </menus>
                </MenuBar>
                <TitledPane text="目标与请求配置">
                    <content>
                        <VBox spacing="8.0">
                            <children>
                                <HBox spacing="8.0">
                                    <children>
                                        <ComboBox fx:id="methodOpt" prefWidth="100.0" />
                                        <TextField fx:id="targetAddress" prefWidth="640.0" promptText="http://target/path" />
                                        <Label text="超时/s" />
                                        <TextField fx:id="httpTimeout" prefWidth="90.0" />
                                    </children>
                                </HBox>
                                <HBox spacing="8.0">
                                    <children>
                                        <Label text="Header" />
                                        <TextField fx:id="globalHeader" prefWidth="520.0" promptText="K1:V1&&&K2:V2" />
                                        <Label text="POST" />
                                        <TextField fx:id="post_data" prefWidth="380.0" promptText="a=1&amp;b=2" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </TitledPane>
                <TitledPane text="检测与攻击基础参数">
                    <content>
                        <VBox spacing="8.0">
                            <children>
                                <HBox spacing="8.0">
                                    <children>
                                        <Label text="Cookie关键字" />
                                        <TextField fx:id="shiroKeyWord" prefWidth="110.0" />
                                        <Label text="指定Key" />
                                        <TextField fx:id="shiroKey" prefWidth="320.0" />
                                        <CheckBox fx:id="aesGcmOpt" mnemonicParsing="false" text="AES GCM" />
                                        <Button fx:id="crackSpcKeyBtn" mnemonicParsing="false" onAction="#crackSpcKeyBtn" text="检测当前密钥" />
                                        <Button fx:id="crackKeyBtn" mnemonicParsing="false" onAction="#crackKeyBtn" text="爆破密钥" />
                                    </children>
                                </HBox>
                                <HBox spacing="8.0">
                                    <children>
                                        <Label text="利用链" />
                                        <ComboBox fx:id="gadgetOpt" prefWidth="270.0" />
                                        <Label text="回显" />
                                        <ComboBox fx:id="echoOpt" prefWidth="220.0" />
                                        <Button fx:id="crackSpcGadgetBtn" mnemonicParsing="false" onAction="#crackSpcGadgetBtn" text="检测当前利用链" />
                                        <Button fx:id="crackGadgetBtn" mnemonicParsing="false" onAction="#crackGadgetBtn" text="爆破利用链及回显" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </TitledPane>
            </children>
            <padding>
                <Insets bottom="4.0" left="6.0" right="6.0" top="6.0" />
            </padding>
        </VBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="检测日志">
                    <content>
                        <TextArea fx:id="logTextArea" />
                    </content>
                </Tab>
                <Tab text="命令执行">
                    <content>
                        <VBox spacing="10.0">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="输入命令" />
                                        <TextField fx:id="exCommandText" prefWidth="820.0" />
                                        <Button fx:id="executeCmdBtn" mnemonicParsing="false" onAction="#executeCmdBtn" text="执行" />
                                    </children>
                                </HBox>
                                <TextArea fx:id="execOutputArea" />
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="内存马注入">
                    <content>
                        <VBox spacing="10.0">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="类型" />
                                        <ComboBox fx:id="memShellOpt" prefWidth="190.0" />
                                        <Label text="路径" />
                                        <TextField fx:id="shellPathText" prefWidth="360.0" />
                                        <Label text="密码" />
                                        <TextField fx:id="shellPassText" prefWidth="140.0" />
                                        <Button fx:id="injectShellBtn" mnemonicParsing="false" onAction="#injectShellBtn" text="执行注入" />
                                    </children>
                                </HBox>
                                <TextArea fx:id="InjOutputArea" />
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Echo Generator">
                    <content>
                        <VBox spacing="10.0">
                            <children>
                                <GridPane hgap="10.0" vgap="10.0">
                                    <children>
                                        <Label text="来源" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <ComboBox fx:id="echoSourceOpt" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Server" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <ComboBox fx:id="jegServerOpt" prefWidth="180.0" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                                        <Label text="Model" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="jegModelOpt" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Format" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="jegFormatOpt" prefWidth="180.0" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                                        <Button fx:id="genEchoBtn" mnemonicParsing="false" onAction="#genEchoBtn" text="生成/回退生成" GridPane.columnIndex="4" GridPane.rowIndex="0" GridPane.rowSpan="2" />
                                    </children>
                                </GridPane>
                                <TextArea fx:id="echoGeneratorOutput" />
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Memshell Generator">
                    <content>
                        <VBox spacing="10.0">
                            <children>
                                <GridPane hgap="10.0" vgap="10.0">
                                    <children>
                                        <Label text="来源" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <ComboBox fx:id="memshellSourceOpt" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Tool" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <ComboBox fx:id="jmgToolOpt" prefWidth="180.0" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                                        <Label text="Server" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="jmgServerOpt" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Shell" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="jmgShellOpt" prefWidth="180.0" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                                        <Label text="Format" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <ComboBox fx:id="jmgFormatOpt" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label text="Gadget" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                        <ComboBox fx:id="jmgGadgetOpt" prefWidth="180.0" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                                        <Button fx:id="genMemshellBtn" mnemonicParsing="false" onAction="#genMemshellBtn" text="生成/回退生成" GridPane.columnIndex="4" GridPane.rowIndex="0" GridPane.rowSpan="3" />
                                    </children>
                                </GridPane>
                                <TextArea fx:id="memshellGeneratorOutput" />
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="key生成">
                    <content>
                        <VBox spacing="8.0">
                            <children>
                                <Button fx:id="keygen" mnemonicParsing="false" onAction="#Keytxt" text="生成key" />
                                <TextArea fx:id="keytxt" />
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom>
        <HBox>
            <children>
                <Label fx:id="proxyStatusLabel" prefWidth="800.0" />
                <Label text="BY SummerSec" />
            </children>
            <padding>
                <Insets bottom="5.0" left="8.0" right="8.0" top="5.0" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>
